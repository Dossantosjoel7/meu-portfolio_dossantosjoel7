---
// src/pages/pt/blog/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

// Fetch only Portuguese blog posts
const allPosts = await getCollection('blog', ({ id }) => {
  return id.startsWith('pt/');
});

// Sort by date descending
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const getTagIcon = (tag: string) => {
  const t = tag.toLowerCase();
  if (t.includes('astro')) return 'code';
  if (t.includes('tailwind')) return 'palette';
  if (t.includes('architecture') || t.includes('arquitetura')) return 'cloud';
  if (t.includes('c++')) return 'memory';
  if (t.includes('python')) return 'integration_instructions';
  if (t.includes('rust')) return 'hub';
  if (t.includes('linux')) return 'terminal';
  if (t.includes('security')) return 'security';
  if (t.includes('ai') || t.includes('ia')) return 'psychology';
  if (t.includes('debugging')) return 'bug_report';
  return 'label';
};

const getCategoryClasses = (category: string) => {
  const c = category.toUpperCase();
  if (c === 'DEVLOG') return 'text-cyber-orange border-cyber-orange/30 bg-cyber-orange/5';
  if (c === 'TUTORIAL') return 'text-electric-blue border-electric-blue/30 bg-electric-blue/5';
  if (c === 'IT INSIGHTS') return 'text-on-tertiary-container border-tertiary-container/30 bg-tertiary-container/5';
  return 'text-electric-blue border-electric-blue/30 bg-electric-blue/5';
};

const title = "Joel Luis dos Santos | Diário Dev";
const description = "Documentação de desafios técnicos, as minhas ideias e vários tópicos. Dá uma vista de olhos.";
---

<BaseLayout title={title} description={description} lang="pt">
  
  <div class="max-w-7xl mx-auto w-full px-margin-page pb-section-gap">
    <!-- Hero / Intro -->
    <section class="mb-stack-lg border-l-2 border-electric-blue pl-8 py-4">
      <h1 class="font-headline-xl text-headline-xl mb-stack-sm tracking-tighter">
        O meu <span class="text-electric-blue">Diário Dev</span>
      </h1>
      <p class="font-body-lg text-body-lg text-text-muted max-w-2xl terminal-cursor">
        Documentação de desafios técnicos, as minhas ideias e vários tópicos. Dá uma vista de olhos.
      </p>
    </section>

    <!-- Filters/Sub-nav -->
    <div class="flex flex-wrap gap-4 mb-stack-lg">
      <button class="px-4 py-2 border border-electric-blue bg-electric-blue/10 text-electric-blue font-label-md text-label-md rounded">Todos os Logs</button>
      <button class="px-4 py-2 border border-surface-border hover:border-electric-blue text-text-muted hover:text-on-surface font-label-md text-label-md rounded transition-all">Devlog</button>
      <button class="px-4 py-2 border border-surface-border hover:border-electric-blue text-text-muted hover:text-on-surface font-label-md text-label-md rounded transition-all">Tutorial</button>
      <button class="px-4 py-2 border border-surface-border hover:border-electric-blue text-text-muted hover:text-on-surface font-label-md text-label-md rounded transition-all">Insights TI</button>
    </div>

    <!-- Devlog Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter-grid">
      
      {sortedPosts.map(post => (
        <article class="flex flex-col bg-surface-card border border-surface-border rounded-lg p-6 group hover:border-electric-blue glow-border transition-all duration-300 h-full">
          <div class="flex justify-between items-start mb-stack-md">
            <span class={`font-label-sm text-label-sm border px-2 py-1 rounded ${getCategoryClasses(post.data.category)}`}>
              {post.data.category.toUpperCase()}
            </span>
            <div class="text-right">
              <p class="font-label-sm text-label-sm text-text-muted">
                {post.data.date.toLocaleDateString('pt-PT', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase()}
              </p>
              <p class="font-label-sm text-label-sm text-text-muted">{post.data.readTime.toUpperCase()}</p>
            </div>
          </div>
          <h3 class="font-headline-md text-headline-md mb-stack-sm leading-tight group-hover:text-electric-blue transition-colors">
            {post.data.title}
          </h3>
          <p class="font-body-md text-body-md text-text-muted mb-stack-md flex-grow">
            {post.data.description}
          </p>
          <div class="flex flex-wrap gap-2 mb-stack-md">
            {post.data.tags.map(tag => (
              <div class="flex items-center gap-1.5 px-2 py-1 bg-surface-container-highest border border-surface-border rounded font-label-sm text-label-sm">
                <span class="material-symbols-outlined text-[14px]">{getTagIcon(tag)}</span>
                {tag}
              </div>
            ))}
          </div>
          
          <a class="inline-flex items-center gap-2 text-electric-blue font-label-md text-label-md group/link" href={`/pt/blog/${post.id.replace('pt/', '').replace(/\.mdx?$/, '')}`}>
            LER_LOG_COMPLETO
            <span class="material-symbols-outlined group-hover/link:translate-x-1 transition-transform" data-icon="keyboard_arrow_right">keyboard_arrow_right</span>
          </a>
        </article>
      ))}

      <!-- Featured Image Card - HIDDEN FOR NOW -->
      <div class="hidden lg:col-span-1 border border-surface-border rounded-lg overflow-hidden relative group">
        <div class="absolute inset-0 bg-gradient-to-t from-surface-main via-transparent to-transparent z-10"></div>
        <div class="w-full h-full min-h-[300px] bg-cover bg-center transition-transform duration-700 group-hover:scale-110" 
             style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDLdC7ie2ghON80ycF8Y-9fU0lBIX_HFt52i5UO_yNJBEzXPFReZiEpNue0U3lFZUjD5oKtus8oYz83WyFPqO0THOqww0gSbrmrzHU-58ju1qEWldGURv1EJkV8IMlowsLKyq68QcUcO-TFAZN7ZNaoiW22OxqgUzLoC_47i9OZzndS9vE_y55_5xXyRZdW1sNfpKzg0bHAEPMMCQO6BxSUwYvquHos8ObnEZPPDHwXLy2a761PqGk')"></div>
        <div class="absolute bottom-6 left-6 z-20">
          <h4 class="font-headline-md text-headline-md text-white mb-2">Visualizando a Lógica</h4>
          <p class="font-label-sm text-label-sm text-electric-blue font-bold tracking-widest uppercase">The Workspace Series</p>
        </div>
      </div>
    </div>

    <!-- Pagination - HIDDEN FOR NOW -->
    <div class="hidden mt-stack-lg flex justify-center items-center gap-4">
      <button class="w-12 h-12 flex items-center justify-center border border-surface-border rounded text-text-muted hover:border-electric-blue hover:text-electric-blue transition-all">
        <span class="material-symbols-outlined" data-icon="chevron_left">chevron_left</span>
      </button>
      <div class="flex gap-2">
        <span class="w-12 h-12 flex items-center justify-center border border-electric-blue text-electric-blue font-bold rounded">01</span>
        <button class="w-12 h-12 flex items-center justify-center border border-surface-border text-text-muted hover:border-electric-blue hover:text-electric-blue rounded transition-all">02</button>
        <button class="w-12 h-12 flex items-center justify-center border border-surface-border text-text-muted hover:border-electric-blue hover:text-electric-blue rounded transition-all">03</button>
        <span class="w-12 h-12 flex items-center justify-center text-text-muted">...</span>
      </div>
      <button class="w-12 h-12 flex items-center justify-center border border-surface-border rounded text-text-muted hover:border-electric-blue hover:text-electric-blue transition-all">
        <span class="material-symbols-outlined" data-icon="chevron_right">chevron_right</span>
      </button>
    </div>
  </div>
</BaseLayout>
