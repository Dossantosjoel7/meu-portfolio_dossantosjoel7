---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/globals.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ id }) => id.startsWith('pt/'));
  return posts.map(post => {
    const slugWithoutLang = post.id.replace('pt/', '').replace(/\.mdx?$/, '');
    return {
      params: { slug: slugWithoutLang },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await render(post);

const getTagIcon = (tag: string) => {
  const t = tag.toLowerCase();
  if (t.includes('astro')) return 'code';
  if (t.includes('tailwind')) return 'palette';
  if (t.includes('architecture') || t.includes('arquitetura')) return 'cloud';
  if (t.includes('c++')) return 'memory';
  if (t.includes('python')) return 'integration_instructions';
  if (t.includes('rust')) return 'hub';
  if (t.includes('linux')) return 'terminal';
  if (t.includes('security')) return 'security';
  if (t.includes('ai') || t.includes('ia')) return 'psychology';
  if (t.includes('debugging')) return 'bug_report';
  return 'label';
};

const title = `${post.data.title} | Blog`;
---

<BaseLayout title={title} description={post.data.description} lang="pt">
  <!-- Fake Background to give Modal effect -->
  <div class="fixed inset-0 bg-surface-main/50 z-0 pointer-events-none"></div>

  <!-- Modal Overlay / Page Wrapper -->
  <div class="fixed inset-0 z-50 flex items-center justify-center p-4 md:p-8">
    <!-- Backdrop blur -->
    <div class="absolute inset-0 bg-surface-main/90 backdrop-blur-md pointer-events-none"></div>
    
    <!-- Modal Content Container -->
    <div class="relative w-full max-w-5xl h-full max-h-[921px] bg-surface-card border border-surface-border rounded-xl shadow-2xl flex flex-col overflow-hidden animate-in fade-in zoom-in duration-300">
      
      <!-- Modal Header -->
      <header class="flex-shrink-0 flex items-center justify-between px-8 py-6 border-b border-surface-border bg-surface-container-lowest/50">
        <div class="flex flex-col gap-1">
          <div class="flex items-center gap-3">
            <span class="text-electric-blue font-label-sm text-label-sm tracking-widest uppercase">System.{post.data.category}</span>
            <div class="h-1 w-1 rounded-full bg-surface-border"></div>
            <span class="text-text-muted font-label-sm text-label-sm">{post.data.date.toLocaleDateString('pt-PT', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase()}</span>
            <div class="h-1 w-1 rounded-full bg-surface-border"></div>
            <span class="text-text-muted font-label-sm text-label-sm">{post.data.readTime}</span>
          </div>
          <h1 class="font-headline-lg text-headline-lg text-on-surface mt-1">{post.data.title}</h1>
        </div>
        <a href="/pt/blog" class="w-12 h-12 flex items-center justify-center rounded-full border border-surface-border hover:border-electric-blue transition-all duration-300 group">
          <span class="material-symbols-outlined text-on-surface-variant group-hover:text-electric-blue transition-colors" data-icon="close">close</span>
        </a>
      </header>

      <!-- Scrollable Body (Markdown Content) -->
      <main class="flex-grow overflow-y-auto custom-scrollbar p-8 md:p-12 space-y-stack-lg prose-custom">
        <div class="flex flex-wrap gap-2 mb-8">
          {post.data.tags.map(tag => (
            <div class="flex items-center gap-1.5 px-3 py-1 bg-surface-main border border-surface-border rounded-full font-label-sm text-label-sm text-on-surface-variant cursor-default hover:border-electric-blue transition-colors">
              <span class="material-symbols-outlined text-[14px] text-electric-blue">{getTagIcon(tag)}</span>
              {tag}
            </div>
          ))}
        </div>

        <div class="markdown-content">
          <Content />
        </div>
      </main>

      <!-- Modal Footer -->
      <footer class="flex-shrink-0 border-t border-surface-border p-6 bg-surface-container-low flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex items-center gap-4">
          <button class="flex items-center gap-3 group text-on-surface-variant hover:text-electric-blue transition-colors" onclick="navigator.clipboard.writeText(window.location.href); alert('Link copiado!');">
            <span class="material-symbols-outlined border border-surface-border p-2 rounded-lg group-hover:border-electric-blue" data-icon="share">share</span>
            <span class="font-label-md text-label-md">Partilhar Artigo</span>
          </button>
        </div>
        <div class="flex items-center gap-6 w-full md:w-auto">
          <a href="/pt/blog" class="flex-1 md:flex-none flex items-center justify-center gap-3 bg-surface-main border border-surface-border px-6 py-3 rounded-lg hover:border-electric-blue hover:bg-surface-container transition-all group">
            <span class="material-symbols-outlined text-[18px] group-hover:-translate-x-1 transition-transform" data-icon="arrow_back">arrow_back</span>
            <span class="font-label-md text-label-md text-on-surface">Voltar aos Blogs</span>
          </a>
        </div>
      </footer>
    </div>
  </div>
</BaseLayout>

<style is:global>
    /* Global styles for rendered markdown content inside modal */
    .markdown-content h2 {
      font-family: 'Geist', sans-serif;
      font-size: 1.5rem;
      font-weight: 600;
      color: #007AFF;
      margin-top: 2rem;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .markdown-content h3 {
      font-family: 'Geist', sans-serif;
      font-size: 1.25rem;
      font-weight: 600;
      color: #e3e2e7;
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
    }
    .markdown-content p {
      margin-bottom: 1rem;
      line-height: 1.6;
      color: #c4c6d0;
      font-size: 1.125rem;
    }
    .markdown-content pre {
      background-color: #050505;
      border: 1px solid #222222;
      border-radius: 0.5rem;
      padding: 1.5rem;
      overflow-x: auto;
      margin-top: 1rem;
      margin-bottom: 1.5rem;
      font-family: monospace;
      font-size: 0.875rem;
      box-shadow: inset 0 2px 4px 0 rgb(0 0 0 / 0.05);
    }
    .markdown-content code {
      background-color: #1e1f23;
      color: #007AFF;
      padding: 0.125rem 0.375rem;
      border-radius: 0.25rem;
      font-size: 0.875em;
    }
    .markdown-content pre code {
      background-color: transparent;
      color: inherit;
      padding: 0;
    }
    .markdown-content ul {
      list-style-type: disc;
      padding-left: 1.5rem;
      margin-bottom: 1rem;
      color: #c4c6d0;
      font-size: 1.125rem;
    }
    .markdown-content ol {
      list-style-type: decimal;
      padding-left: 1.5rem;
      margin-bottom: 1rem;
      color: #c4c6d0;
      font-size: 1.125rem;
    }
    .markdown-content strong {
      color: #e3e2e7;
      font-weight: 600;
    }
</style>
