---
// src/pages/pt/projects.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import ProjectModal from '../../components/ProjectModal.astro';

const title = "Joel Luis dos Santos | Projetos";
const description = "Explore todos os projetos académicos, pessoais e profissionais desenvolvidos por Joel Luis dos Santos em engenharia de software, desenvolvimento web e TI.";
---

<BaseLayout title={title} description={description} lang="pt">

  <!-- Secção Hero -->
  <section class="px-margin-page mb-section-gap relative z-10">
    <div class="max-w-4xl">
      <div class="flex items-center gap-3 mb-stack-sm">
        <div class="w-8 h-[1px] bg-electric-blue"></div>
        <span class="font-label-sm text-label-sm text-electric-blue uppercase tracking-widest">Repositório</span>
      </div>
      <h1 class="font-headline-xl text-headline-xl mb-4 text-on-surface">Sistema // Projetos</h1>
      <p class="font-body-lg text-body-lg text-text-muted max-w-2xl">Aqui encontras todos os projetos em que trabalhei, seja em contexto profissional, académico ou pessoal.</p>
    </div>
  </section>

  <!-- Secção Projetos Académicos & Pessoais -->
  <section class="px-margin-page relative z-10 mb-section-gap">
    <div class="flex items-baseline justify-between mb-stack-lg border-b border-surface-border pb-4">
      <h2 class="font-headline-lg text-headline-lg text-on-surface">Projetos Académicos & Pessoais</h2>
      <span class="font-label-sm text-label-sm text-text-muted hidden md:inline">INVESTIGAÇÃO & DESENVOLVIMENTO</span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      
      <ProjectCard
        projectId="portfolio"
        title="Portfólio Pessoal"
        subtitle="Aplicação Web Full-Stack"
        status="v2.0 ONLINE"
        description="Um website de portfólio moderno e responsivo construído com Astro e Tailwind CSS v4. Com design dark mode, suporte multilingue (EN/PT) e micro-animações suaves."
        tags={[
          { icon: "code", label: "Astro" },
          { icon: "palette", label: "Tailwind v4" },
          { icon: "language", label: "TypeScript" },
        ]}
        viewDetailsLabel="Ver Detalhes"
      />

    </div>
  </section>

  <!-- Secção CTA -->
  <section class="px-margin-page py-section-gap">
    <div class="bg-surface-container border border-surface-border rounded-lg p-12 text-center relative overflow-hidden">
      <h2 class="font-headline-lg text-headline-lg text-on-surface mb-6">Precisas de me contactar?</h2>
      <p class="max-w-2xl mx-auto font-body-lg text-body-lg text-text-muted mb-10">
        Estou disponível para projetos de desenvolvimento de nível júnior em web, mobile e suporte técnico. Vamos conversar.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/pt/contact" class="bg-cyber-orange text-on-secondary-fixed px-10 py-4 rounded font-label-md text-label-md font-bold hover:scale-105 transition-all flex items-center gap-2 justify-center">
          Iniciar uma Conversa <span class="material-symbols-outlined">arrow_forward</span>
        </a>
      </div>
      <!-- Efeito glow subtil -->
      <div class="absolute -z-10 bottom-0 right-0 w-64 h-64 bg-cyber-orange/10 blur-[100px] rounded-full"></div>
      <div class="absolute -z-10 top-0 left-0 w-64 h-64 bg-electric-blue/10 blur-[100px] rounded-full"></div>
    </div>
  </section>

  <!-- Modal de Projeto -->
  <ProjectModal lang="pt" />

  <!-- Dados dos Projetos para o Modal -->
  <script>
    (window as any).__PROJECTS_DATA__ = {
      "portfolio": {
        title: "Portfólio Pessoal",
        icon: "web",
        image: "",
        overview: "Um website de portfólio moderno e responsivo construído com Astro e Tailwind CSS v4. Com um sistema de design premium em dark mode com efeitos de glassmorphism, suporte multilingue (EN/PT) e micro-animações suaves para uma experiência de utilizador envolvente.",
        challenge: "Criar uma presença online profissional que se destaque, funcione perfeitamente em todos os dispositivos e suporte múltiplos idiomas sem duplicar toda a base de código.",
        solution: "Utilizar a arquitetura de componentes do Astro para elementos de UI reutilizáveis e geração estática, combinada com o sistema de design tokens do Tailwind CSS v4 para uma linguagem de design consistente e escalável.",
        techStack: [
          { icon: "code", label: "Astro" },
          { icon: "palette", label: "Tailwind v4" },
          { icon: "language", label: "TypeScript" },
          { icon: "dns", label: "Vercel" },
        ],
        metrics: [
          { label: "Pontuação Lighthouse", value: "98+" },
          { label: "Primeiro Render", value: "< 0.5s" },
          { label: "Idiomas", value: "EN / PT" },
        ],
        features: ["Design Dark Mode", "Multilingue (i18n)", "Otimizado para SEO"],
        github: "https://github.com/Dossantosjoel7/meu-portfolio_dossantosjoel7",
        demo: "/pt/portfolio",
        statusText: "Online",
      }
    };
  </script>

</BaseLayout>
