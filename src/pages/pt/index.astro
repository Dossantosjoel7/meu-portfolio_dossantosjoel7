---
// src/pages/pt/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import SkillCard from '../../components/SkillCard.astro';
import ExperienceCard from '../../components/ExperienceCard.astro';

const title = "Joel Luis dos Santos | Portfólio";
const description = "Estudante de Engenharia Informática e Entusiasta de Tecnologia, com foco em Engenharia de Software, Suporte de TI e soluções tecnológicas inovadoras.";
---

<BaseLayout title={title} description={description} lang="pt">
  
  <section class="min-h-[819px] flex flex-col md:flex-row items-center px-margin-page py-stack-lg gap-gutter-grid transition-all duration-1000 opacity-100 translate-y-0">
    <div class="w-full md:w-1/2 flex flex-col gap-stack-md">
      <div class="space-y-2">
        <h1 class="font-headline-xl-mobile md:font-headline-xl text-headline-xl-mobile md:text-headline-xl text-on-surface">
          Olá, eu sou o <span class="text-on-surface">Joel</span>
        </h1>
        <div class="flex flex-col gap-1">
          <span class="font-headline-lg text-headline-lg text-electric-blue">🎓Estudante de Engenharia Informática🚀</span>
          <span class="font-headline-lg text-headline-lg text-cyber-orange">& Entusiasta de Tecnologia👨‍💻</span>
        </div>
      </div>
      <div class="flex flex-wrap gap-4 mt-4">
        <a class="bg-electric-blue text-white flex items-center gap-2 px-8 py-4 font-label-md text-label-md rounded-lg glow-blue hover:scale-105 transition-all" href="#projects">
          Ver Projetos <span class="material-symbols-outlined">arrow_forward</span>
        </a>
        <a class="border border-cyber-orange text-cyber-orange flex items-center gap-2 px-8 py-4 font-label-md text-label-md rounded-lg hover:bg-cyber-orange/10 transition-all" href="#contact">
          Conectar comigo <span class="material-symbols-outlined">arrow_forward</span>
        </a>
      </div>
    </div>
    <div class="w-full md:w-1/2 flex flex-col justify-center gap-stack-md border-l border-surface-border md:pl-12">
      <p class="font-body-lg text-body-lg text-on-surface leading-relaxed">
        Sou um entusiasta de tecnologia, guiado por princípios sólidos, compromisso com o rigor no meu trabalho e uma forte vontade de aprender. O meu objetivo é procurar sempre novos desafios que impulsionem o meu crescimento pessoal e profissional.
      </p>
      <p class="font-body-md text-body-md text-text-muted">
        Estou empenhado em integrar projetos onde possa aplicar o meu conhecimento técnico e contribuir com verdadeiro valor.
      </p>
      <div class="flex items-center gap-8 pt-6">
        <a class="flex items-center gap-2 font-label-sm text-label-sm text-on-surface hover:text-electric-blue transition-colors" href="/cv_pt(2026).pdf" target="_blank">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">description</span>
          Currículo
        </a>
        <a class="flex items-center gap-2 font-label-sm text-label-sm text-on-surface hover:text-electric-blue transition-colors" href="https://linkedin.com/in/joel-luís-dos-santos-0ba20b286">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">share</span>
          LinkedIn
        </a>
        <a class="flex items-center gap-2 font-label-sm text-label-sm text-on-surface hover:text-electric-blue transition-colors" href="https://github.com/Dossantosjoel7">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">code</span>
          GitHub
        </a>
      </div>
    </div>
  </section>

<!-- Skills Section -->
  <section class="px-margin-page" id="skills">
    <div class="mb-16">
      <h2 class="font-headline-lg text-headline-lg text-on-surface mb-2">Competências & <span class="text-electric-blue">Tecnologias</span></h2>
      <p class="font-body-md text-body-md text-text-muted">O meu conjunto de ferramentas técnicas no ecossistema de software.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <SkillCard 
        title="Desenvolvimento Front-End & Back-End" 
        titleColor="blue"
        skills={["HTML & CSS", "JavaScript", "Python", "C", "C++", "Tailwind", "React", "Astro", "Node.js", "PHP"]} 
      />

      <SkillCard 
        title="Helpdesk / Suporte de TI" 
        titleColor="orange"
        skills={["Virtualização"]} 
      />

      <SkillCard 
        title="Engenharia de Software & Metodologias" 
        titleColor="blue"
        skills={["UML", "Análise de Requisitos", "Modelação de Sistemas", "Testes Manuais & Automatizados"]} 
      />

      <SkillCard 
        title="Bases de Dados, Armazenamento & Cloud" 
        titleColor="orange"
        skills={["MySQL", "Oracle SQL"]} 
      />

      <SkillCard 
        title="DevOps" 
        titleColor="blue"
        skills={["Docker"]} 
      />

      <SkillCard 
        title="Ferramentas" 
        titleColor="orange"
        skills={["Git", "GitHub", "VS Code", "StarUML", "Draw.io", "Google Antigravity"]} 
      />

      <SkillCard 
        title="Outros" 
        titleColor="blue"
        skills={["Blender"]} 
      />

    </div>
  </section>

  <!-- Experience Section -->
   <section class="px-margin-page py-section-gap" id="experience">
  <div class="mb-16">
    <h2 class="font-headline-lg text-headline-lg text-on-surface mb-2">Experiência</h2>
    <p class="font-body-md text-body-md text-text-muted">O meu percurso profissional até agora.</p>
  </div>
  
  <div class="relative border-l-2 border-surface-border ml-4 space-y-12 pl-10">
    
    <!-- 1. TW Twins Lda-->
    <ExperienceCard 
      role="Assistente de TI"
      company="TW Twins Lda"
      companyColor="orange"
      date="Abr 2023 — Jun 2023"
      location="Luanda, Angola · Presencial"
      type="Estágio Curricular"
      dotColor="orange"
      description={[
        "- Realizei diagnósticos e manutenção de hardware enquanto criava simultaneamente um inventário abrangente da empresa...",
        "- Configurei máquinas virtuais (Windows 8.1 e Linux Ubuntu) via Oracle VM VirtualBox...",
        "- Desenvolvi documentação técnica padronizada e realizei uma análise SWOT..."
      ]}
      tags={["Suporte de TI", "Virtualização", "Documentação", "Inventário", "Análise SWOT"]}
    />

    <!-- 2. Sui Foundation (Consultor)
    <ExperienceCard 
      role="Consultor"
      company="Sui Foundation"
      companyColor="blue"
      date="Abr 2025 — Out 2025"
      location="Ilhas Caimão · Remoto"
      type="Contrato"
      dotColor="gray"
      description={[
        "Desempenhei um papel crucial na elevação de plataformas web. Focado na modernização do ecossistema UI/UX, impulsionando iniciativas que melhoram o envolvimento do utilizador e simplificam os processos de desenvolvimento."
      ]}
      projects="SuiNS Governance"
      tags={["Tailwind CSS", "React", "Sui"]}
    />-->

    <!-- 3. Selenium (Frontend Developer) 
    <ExperienceCard 
      role="Frontend Developer"
      company="Selenium"
      companyColor="orange"
      date="Set 2025 — Out 2025"
      location="Luanda, Angola · Híbrido"
      type="Contrato"
      dotColor="gray"
      projects="Viva Simulator"
      tags={["React", "HTML5", "Next.js"]}
    />
    -->
  </div>
  </section>
  <section class="px-margin-page py-section-gap" id="contact">
    <div class="bg-surface-container border border-surface-border rounded-lg p-12 text-center relative overflow-hidden">
      <h2 class="font-headline-lg text-headline-lg text-on-surface mb-6">Precisas de me contactar?</h2>
      <p class="max-w-2xl mx-auto font-body-lg text-body-lg text-text-muted mb-10">
        Estou disponível para projetos de desenvolvimento de nível júnior em web, mobile e suporte técnico. Vamos conversar.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="mailto:teu-email@exemplo.com" class="bg-cyber-orange text-on-secondary-fixed px-10 py-4 rounded font-label-md text-label-md font-bold hover:scale-105 transition-all flex items-center gap-2 justify-center">
          Iniciar uma Conversa <span class="material-symbols-outlined">arrow_forward</span>
        </a>
      </div>
      <div class="absolute -z-10 bottom-0 right-0 w-64 h-64 bg-cyber-orange/10 blur-[100px] rounded-full"></div>
      <div class="absolute -z-10 top-0 left-0 w-64 h-64 bg-electric-blue/10 blur-[100px] rounded-full"></div>
    </div>
  </section>

</BaseLayout>