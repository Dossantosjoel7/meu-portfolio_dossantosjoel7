---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
// 1. Importamos o teu molde mestre
import BaseLayout from './BaseLayout.astro'; 

// Adicionamos `altText` como uma propriedade opcional ao tipo Props.
// Isto informa ao TypeScript que `altText` pode ou não vir dos dados do blog.
type Props = CollectionEntry<'blog'>['data'] & { altText?: string };


// 2. Adicionámos altText para puxar a descrição da imagem do ficheiro Markdown
const { title, description, pubDate, updatedDate, heroImage, altText } = Astro.props;
---

<!-- 3. Usamos o BaseLayout para envolver o artigo, passando o SEO automaticamente -->
<BaseLayout title={title} description={description}>
    
    <article class="max-w-3xl mx-auto px-4 py-12">
        <div class="hero-image mb-8">
            {/* O alt text dinâmico é injetado aqui para leitura de Scrapers e IAs */}
            {heroImage && (
                <Image 
                    width={1020} 
                    height={510} 
                    src={heroImage} 
                    alt={altText || title} 
                    class="rounded-xl shadow-lg mx-auto block w-full"
                />
            )}
        </div>
        
        <div class="prose prose-invert max-w-none text-slate-300">
            <div class="text-center mb-8">
                <div class="text-slate-400 mb-3 text-sm font-medium">
                    <FormattedDate date={pubDate} />
                    {
                        updatedDate && (
                            <div class="italic mt-1">
                                Last updated on <FormattedDate date={updatedDate} />
                            </div>
                        )
                    }
                </div>
                <h1 class="text-3xl md:text-4xl font-bold text-slate-100 mb-6">{title}</h1>
                <hr class="border-slate-700 mb-8" />
            </div>
            
            <!-- Aqui entra o texto do teu Devlog escrito em Markdown -->
            <slot />
        </div>
    </article>

</BaseLayout>