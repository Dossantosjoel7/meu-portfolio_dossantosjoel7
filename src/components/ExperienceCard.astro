---
// src/components/ExperienceCard.astro

const {
  role,
  company,
  companyColor = "orange", // "orange" ou "blue"
  date,
  location,
  type,
  description = [], // Array de strings (para parágrafos ou tópicos)
  projects, // Opcional
  tags = [],
  dotColor = "gray" // "orange" ou "gray"
} = Astro.props;

// Lógica de cores
const companyColorClass = companyColor === "blue" ? "text-electric-blue" : "text-cyber-orange";
const dotColorClass = dotColor === "orange" ? "bg-cyber-orange" : "bg-surface-border";
---

<div class="relative">
  <!-- O Ponto na Linha do Tempo -->
  <div class={`absolute -left-[50px] top-0 w-5 h-5 rounded-full border-4 border-surface-main ${dotColorClass}`}></div>
  
  <div class="bg-surface-container border border-surface-border p-8 rounded-lg hover-glow transition-all">
    
    <!-- Cabeçalho do Cartão (Cargo, Empresa, Data, Local) -->
    <div class="flex flex-col md:flex-row md:justify-between items-start mb-6">
      <div>
        <h3 class="font-headline-md text-headline-md text-on-surface">{role}</h3>
        <p class={`${companyColorClass} font-semibold`}>{company}</p>
      </div>
      <div class="text-right mt-2 md:mt-0">
        <span class="font-label-sm text-label-sm text-text-muted block uppercase">{date}</span>
        <span class="font-label-sm text-label-sm text-text-muted block">{location}</span>
      </div>
    </div>

    <!-- Tipo de Contrato (Estágio, Contrato, etc.) -->
    {type && (
      <div class="flex gap-2 mb-6">
        <span class="px-3 py-1 bg-surface-main border border-surface-border text-xs rounded uppercase tracking-wider text-text-muted">
          {type}
        </span>
      </div>
    )}

    <!-- Descrição (Mapeia o array de textos. Se estiver vazio, não renderiza nada) -->
    {description.length > 0 && (
      <div class="mb-6 space-y-2">
        {description.map((paragraph:string) => (
          <p class="font-body-md text-body-md text-text-muted">{paragraph}</p>
        ))}
      </div>
    )}

    <!-- Projetos (Renderiza apenas se houver algum projeto passado como Prop) -->
    {projects && (
      <p class="text-xs font-label-md uppercase text-text-muted mb-3 tracking-widest">
        Projetos: {projects}
      </p>
    )}

    <!-- Tags / Tecnologias -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {tags.map((tag:string) => (
          <span class="px-3 py-1 bg-surface-container-high rounded text-xs">{tag}</span>
        ))}
      </div>
    )}

  </div>
</div>