---
// src/components/Header.astro
const { lang: langProp = 'en' } = Astro.props;

// Dicionário de Traduções para o Menu
const t = {
  en: { home: "Home", projects: "Projects", blog: "Blog", contact: "Contact", cv: "Download CV" },
  pt: { home: "Início", projects: "Projetos", blog: "Blog", contact: "Contactos", cv: "Descarregar CV" }
} as const;

// Caminhos para os ficheiros do CV
const cvPaths = {
  en: '/cv_en(2026).pdf', // Assumindo que o CV em inglês existe neste caminho
  pt: '/cv_pt(2026).pdf'
};

// Tipagem para garantir que 'lang' é uma chave válida de 't'
type Lang = keyof typeof t;
const lang = langProp as Lang;

const pathname = Astro.url.pathname;
// A rota ativa é considerada Home se for a raiz ou o pt raiz
const isHome = pathname === '/' || pathname === '/index.html' || pathname === '/pt' || pathname === '/pt/';
const isBlog = pathname.startsWith('/blog') || pathname.startsWith('/pt/blog');
const isContact = pathname.startsWith('/contact') || pathname.startsWith('/pt/contact');
const isProjects = pathname.startsWith('/projects') || pathname.startsWith('/pt/projects');

// Gerar URLs dinâmicos para a troca de idioma
const isPtRoute = pathname.startsWith('/pt');
let basePage = pathname;
if (isPtRoute) {
  basePage = pathname.substring(3); // Remove '/pt'
}
// Limpar caminhos vazios ou sem barra inicial
if (basePage === '' || basePage === '/') {
  basePage = '/';
} else if (!basePage.startsWith('/')) {
  basePage = '/' + basePage;
}

const enUrl = basePage;
const ptUrl = basePage === '/' ? '/pt/' : `/pt${basePage}`;
---

<div class="fixed top-4 left-0 right-0 z-50 px-margin-page flex flex-col items-center">
  <nav id="main-nav" class="w-full max-w-7xl backdrop-blur-md border border-surface-border rounded-full flex justify-between items-center px-8 py-3 transition-all duration-300 bg-surface-main/40">

    <div class="flex flex-col">
      <span class="font-headline-md text-headline-md font-bold text-on-surface tracking-tighter leading-none mb-2">Joel Luis dos Santos</span>
      <span class="font-label-sm text-label-sm text-text-muted leading-none">👨‍💻 Tech Enthusiast | 🎓Computer Science & Engineering Student🚀</span>
    </div>

    <!-- Navigation Links (Center) - Desktop -->
    <div class="hidden md:flex gap-8 items-center">
      <a class={`font-label-sm text-label-sm transition-colors ${isHome ? "text-electric-blue relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-full after:h-0.5 after:bg-electric-blue" : "text-text-muted hover:text-electric-blue"}`} href={isPtRoute ? "/pt/" : "/"}>{t[lang].home}</a>
      <a class={`font-label-sm text-label-sm transition-colors ${isProjects ? "text-electric-blue relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-full after:h-0.5 after:bg-electric-blue" : "text-text-muted hover:text-electric-blue"}`} href={isPtRoute ? "/pt/projects" : "/projects"}>{t[lang].projects}</a>
      <a class={`font-label-sm text-label-sm transition-colors ${isBlog ? "text-electric-blue relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-full after:h-0.5 after:bg-electric-blue" : "text-text-muted hover:text-electric-blue"}`} href={isPtRoute ? "/pt/blog" : "/blog"}>{t[lang].blog}</a>
      <a class={`font-label-sm text-label-sm transition-colors ${isContact ? "text-electric-blue relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-full after:h-0.5 after:bg-electric-blue" : "text-text-muted hover:text-electric-blue"}`} href={isPtRoute ? "/pt/contact" : "/contact"}>{t[lang].contact}</a>
    </div>

    <div class="flex items-center gap-6">
      
      <div class="hidden md:flex items-center bg-surface-container-high rounded-full p-1 border border-surface-border">
        <a href={enUrl} class={`px-3 py-1 rounded-full font-label-sm text-label-sm transition-colors ${lang === 'en' ? 'bg-electric-blue text-white shadow-sm' : 'text-text-muted hover:text-on-surface'}`}>EN</a>
        <a href={ptUrl} class={`px-3 py-1 rounded-full font-label-sm text-label-sm transition-colors ${lang === 'pt' ? 'bg-electric-blue text-white shadow-sm' : 'text-text-muted hover:text-on-surface'}`}>PT</a>
      </div>

      <a href={cvPaths[lang]} download class="hidden md:flex bg-electric-blue text-white px-5 py-2.5 font-label-sm text-label-sm rounded-full active:opacity-80 active:scale-95 hover:bg-electric-blue/90 transition-all items-center gap-2">
        {t[lang].cv}
        <span class="material-symbols-outlined">download</span>
      </a>

      <!-- Mobile Menu Trigger -->
      <button id="mobile-menu-trigger" class="hidden max-md:flex text-on-surface items-center justify-center p-2 rounded-full hover:bg-surface-container-high transition-all" aria-expanded="false" aria-label="Toggle menu">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden w-full max-w-7xl mt-2 backdrop-blur-md border border-surface-border rounded-2xl p-6 shadow-xl bg-surface-main/90 flex-col gap-6 transition-all duration-300 origin-top transform scale-y-95 opacity-0">
    <div class="flex flex-col gap-4">
      <a class={`font-label-sm text-label-sm py-2 border-b border-surface-border/50 ${isHome ? "text-electric-blue" : "text-text-muted hover:text-electric-blue transition-colors"}`} href={isPtRoute ? "/pt/" : "/"}>{t[lang].home}</a>
      <a class={`font-label-sm text-label-sm py-2 border-b border-surface-border/50 ${isProjects ? "text-electric-blue" : "text-text-muted hover:text-electric-blue transition-colors"}`} href={isPtRoute ? "/pt/projects" : "/projects"}>{t[lang].projects}</a>
      <a class={`font-label-sm text-label-sm py-2 border-b border-surface-border/50 ${isBlog ? "text-electric-blue" : "text-text-muted hover:text-electric-blue transition-colors"}`} href={isPtRoute ? "/pt/blog" : "/blog"}>{t[lang].blog}</a>
      <a class={`font-label-sm text-label-sm py-2 ${isContact ? "text-electric-blue" : "text-text-muted hover:text-electric-blue transition-colors"}`} href={isPtRoute ? "/pt/contact" : "/contact"}>{t[lang].contact}</a>
    </div>
    
    <div class="h-px bg-surface-border w-full"></div>
    
    <div class="flex items-center justify-between">
      <span class="font-label-sm text-label-sm text-text-muted">Language / Idioma</span>
      <div class="flex items-center bg-surface-container-high rounded-full p-1 border border-surface-border">
        <a href={enUrl} class={`px-3 py-1 rounded-full font-label-sm text-label-sm transition-colors ${lang === 'en' ? 'bg-electric-blue text-white shadow-sm' : 'text-text-muted hover:text-on-surface'}`}>EN</a>
        <a href={ptUrl} class={`px-3 py-1 rounded-full font-label-sm text-label-sm transition-colors ${lang === 'pt' ? 'bg-electric-blue text-white shadow-sm' : 'text-text-muted hover:text-on-surface'}`}>PT</a>
      </div>
    </div>
    
    <a href={cvPaths[lang]} download class="w-full bg-electric-blue text-white px-6 py-2 rounded-[0.25rem] py-2 font-label-sm text-label-sm  active:opacity-80 active:scale-95 hover:bg-electric-blue/90 transition-all flex items-center justify-center gap-2">
      {t[lang].cv}
      <span class="material-symbols-outlined">download</span>
    </a>
  </div>
</div>

<script>
  function setupHeaderScroll() {
    const nav = document.getElementById('main-nav');
    if (!nav) return;
    
    const handleScroll = () => {
      if (window.scrollY > 20) {
        nav.classList.add('bg-surface-main/90', 'shadow-lg');
        nav.classList.remove('bg-surface-main/40');
      } else {
        nav.classList.add('bg-surface-main/40');
        nav.classList.remove('bg-surface-main/90', 'shadow-lg');
      }
    };
    
    window.addEventListener('scroll', handleScroll);
    handleScroll(); // set initial
  }

  function setupMobileMenu() {
    const trigger = document.getElementById('mobile-menu-trigger');
    const menu = document.getElementById('mobile-menu');

    if (trigger && menu) {
      const icon = trigger.querySelector('.material-symbols-outlined');
      
      trigger.addEventListener('click', () => {
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        
        if (isExpanded) {
          // Close menu
          menu.classList.add('opacity-0', 'scale-y-95');
          menu.classList.remove('opacity-100', 'scale-y-100');
          setTimeout(() => {
            menu.classList.add('hidden');
            menu.classList.remove('flex');
          }, 150); // Matches transition duration
          trigger.setAttribute('aria-expanded', 'false');
          if (icon) icon.textContent = 'menu';
        } else {
          // Open menu
          menu.classList.remove('hidden');
          menu.classList.add('flex');
          // Trigger browser layout pass to enable transitions
          void menu.offsetHeight;
          menu.classList.remove('opacity-0', 'scale-y-95');
          menu.classList.add('opacity-100', 'scale-y-100');
          trigger.setAttribute('aria-expanded', 'true');
          if (icon) icon.textContent = 'close';
        }
      });

      // Close menu when clicking a link
      const menuLinks = menu.querySelectorAll('a, button');
      menuLinks.forEach(link => {
        link.addEventListener('click', () => {
          menu.classList.add('opacity-0', 'scale-y-95');
          menu.classList.remove('opacity-100', 'scale-y-100');
          setTimeout(() => {
            menu.classList.add('hidden');
            menu.classList.remove('flex');
          }, 150);
          trigger.setAttribute('aria-expanded', 'false');
          if (icon) icon.textContent = 'menu';
        });
      });

      // Handle window resizing
      window.addEventListener('resize', () => {
        if (window.innerWidth >= 768) {
          menu.classList.add('hidden');
          menu.classList.remove('flex', 'opacity-100', 'scale-y-100');
          menu.classList.add('opacity-0', 'scale-y-95');
          trigger.setAttribute('aria-expanded', 'false');
          if (icon) icon.textContent = 'menu';
        }
      });
    }
  }

  // Setup on page load
  setupHeaderScroll();
  setupMobileMenu();

  // Setup on page transitions if you use View Transitions
  document.addEventListener('astro:after-swap', () => {
    setupHeaderScroll();
    setupMobileMenu();
  });
</script>